<!-- Header / Hero -->
<header>
    <div class="container hero-content fade-in">
        <h1>Harvy &amp; Lorraine</h1>
        <div class="tagline">Celebrating our love – <span class="highlight">June 15, 2025</span></div>
        <a href="#details" class="btn">Wedding Details</a>
    </div>
</header>

<!-- Navigation -->
<nav>
    <ul>
        <li><a href="#story">Our Story</a></li>
        <li><a href="#details">Details</a></li>
        <li><a href="#rsvp">RSVP</a></li>
        <li><a href="#gallery">Gallery</a></li>
        <li><a href="#contact">Contact</a></li>
    </ul>
</nav>

<!-- Our Story -->
<section id="story" class="container">
    <h2 class="section-title">Our Story</h2>
    <div class="grid-2">
        <div>
            <p>We met in the bar called KUYA JAY's of 2016 at SM FAIRVIEW. A shared love for live jazz, spontaneous road trips, and terrible karaoke brought us together.</p>
            <p class="highlight">After nine years of adventures, countless inside jokes, and a lot of late‑night pancakes, Harvy finally got down on one knee…</p>
        </div>
        <div>
            <img src="https://via.placeholder.com/800x500?text=Harvy+%26+Lorraine+Engagement" alt="Engagement photo">
        </div>
    </div>
    <p>We’re excited to share this day with family and friends who have supported us along the way. Thank you for being part of our journey!</p>
</section>

<!-- Wedding Details -->
<section id="details" class="container">
