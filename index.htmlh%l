        <div class="detail-item">
            <i class="far fa-calendar-alt"></i>
            <div>
                <div class="label">Date</div>
                <div class="value">Saturday, June 15, 2025</div>
                <div class="value">Ceremony: 4:00 PM • Reception: 6:30 PM</div>
            </div>
        </div>
        <div class="detail-item">
            <i class="fa-solid fa-location-dot"></i>
            <div>
                <div class="label">Venue</div>
                <div class="value">The Willow Estate</div>
                <div class="value">123 Meadow Lane, Austin, TX 78704</div>
                <div class="value"><a href="https://goo.gl/maps/xyz" target="_blank">View on Google Maps</a></div>
            </div>
        </div>
        <div class="detail-item">
            <i class="fa-solid fa-user-tie"></i>
            <div>
                <div class="label">Attire</div>
                <div class="value">Semi‑formal / Garden chic</div>
                <div class="value">Ladies: sundresses or cocktail attire • Gentlemen: blazers & slacks (no tie required)</div>
            </div>
        </div>
        <div class="detail-item">
            <i class="fa-solid fa-heart"></i>
            <div>
                <div class="label">Registry</div>
                <div class="value">We’ve set up a <a href="https://www.example.com/registry" target="_blank">gift registry</a> for those who wish to contribute.</div>
            </div>
        </div>
    </div>
</section>

