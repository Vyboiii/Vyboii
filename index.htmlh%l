<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Harvy & Lorraine – Our Wedding</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <!-- Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Source+Sans+Pro:wght@400;600&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" integrity="sha512-..."><!-- integrity omitted for brevity -->
    <style>
        /* ---------- Reset & Base ---------- */
        *, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }
        html { font-size: 100%; } /* 16px base */
        body {
            font-family: 'Source Sans Pro', sans-serif;
            line-height: 1.6;
            color: #3783;
            background: #fafafa;
        }
        a { text-decoration: none; color: inherit; }
        img { max-width: 100%; height: auto; display: block; }

        /* ---------- Layout ---------- */
        .container { width: 90%; max-width: 1200px; margin: 0 auto; padding: 1rem 0; }
        header, footer, section { padding: 3rem 0; }

        /* ---------- Header / Hero ---------- */
        header {
            background: linear-gradient(135deg, #fff8f7, #ffe3d9);
            text-align: center;
            position: relative;
            overflow: hidden;
        }
        header::after {
            content:"";
            position:absolute; inset:0;
            background:url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" width="100" height="100" viewBox="0 0 100 100"><rect width="100" height="100" fill="%23fff8f0"/><path d="M0,30 Q50,0 100,30 T200,30" fill="none" stroke="%23ffe5d9" stroke-width="4"/></svg>');
            opacity:0.15;
        }
        .hero-content {
            position:relative; z-index:2;
        }
        .hero-content h1 {
            font-family: 'Playfair Display', serif;
            font-size: 2.8rem;
            margin-bottom: .5rem;
            color: #5a3e2b;
        }
        .hero-content .tagline {
            font-size: 1.2rem;
            color: #777;
            margin-bottom: 1.5rem;
        }
        .btn {
            display:inline-block;
            background:#c0392b;
            color:#fff;
            padding:.8rem 1.5rem;
            border-radius:4px;
            font-weight:600;
            transition:background .3s;
        }
        .btn:hover{background:#a93226;}

        /* ---------- Nav ---------- */
        nav {
            background:#fff;
            box-shadow:0 2px 4px rgba(0,0,0,.08);
            position:sticky; top:0; z-index:1000;
        }
        nav ul {
            display:flex; flex-wrap:wrap; justify-content:center; list-style:none;
            gap:1.5rem;
        }
        nav li a {
            padding:.5rem 0;
            font-weight:600;
            color:#444;
            position:relative;
        }
        nav li a::after{
            content:""; position:absolute; left:0; bottom:-2px;
            width:0; height:2px; background:#c0392b; transition:width .3s;
        }
        nav li a:hover::after{width:100%;}
        nav li a:hover: width:100%;}

        /* ---------- Sections ---------- */
        section { background:#fff; margin:2rem 0; border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,.07); }
        .section-title {
            text-align:center;
            font-family:'Playfair Display',serif;
            font-size:2rem;
            margin-bottom:1.5rem;
            color:#5a3e2b;
            position:relative;
        }
        .section-title::after{
            content:""; display:block; width:60px; height:3px;
            background:#c0392b; margin:0.5rem auto 0;
        }
        .grid-2{display:grid;gap:1.5rem;}
        @media(min-width:768px){ .grid-2{grid-template-columns:1fr 1fr;} }

        /* ---------- Story ---------- */
        .story p{margin-bottom:1rem;}
        .story .highlight{font-weight:600;color:#5a3e2b;}

        /* ---------- Details ---------- */
        .detail-item{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1.2rem;}
        .detail-item i{font-size:1.4rem;color:#c0392b;margin-top:.2rem;}
        .detail-item .info{flex:1;}
        .detail-item .label{font-weight:600;color:#444;}
        .detail-item .value{margin-top:.3rem;}

        /* ---------- RSVP ---------- */
        #rsvp-form{display:grid;gap:1rem;max-width:500px;margin:0 auto;}
        #rsvp-form label{font-weight:600;}
        #rsvp-form input,
        #rsvp-form select,
        #rsvp-form textarea{
            width:100%;padding:.8rem;border:1px solid #ddd;border-radius:4px;font:inherit;
        }
        #rsvp-form button{align-self:start;}
        #rsvp-msg{margin-top:1rem;text-align:center;font-weight:600;display:none;}

        /* ---------- Gallery ---------- */
        .gallery{display:grid;gap:.8rem;}
        @media(min-width:480px){ .gallery{grid-template-columns:repeat(2,1fr);} }
        @media(min-width:768px){ .gallery{grid-template-columns:repeat(3,1fr);} }
        .gallery img{border-radius:6px;transition:transform .3s;}
        .gallery img:hover{transform:scale(1.05);}

        /* ---------- Footer ---------- */
        footer{
            background:#2c3e50;
            color:#ecf0f1;
            text-align:center;
            font-size:.9rem;
        }
        footer a{color:#fff;border-bottom:1px dotted;transition:opacity .3s;}
        footer a:hover{opacity:.7;}

        /* ---------- Animations (optional) ---------- */
        @keyframes fadeIn{from{opacity:0;transform:translateY(20px);}to{opacity:1;transform:translateY(0);}}
        .fade-in{animation:fadeIn .6s ease-out forwards;}
    </style>
</head>
